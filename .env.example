# 千问API配置
QWEN_API_KEY=your_qwen_api_key
QWEN_VOICE_MODEL=qwen-voice-recognition
QWEN_CHAT_MODEL=qwen3-max-2026-01-23

# 应用配置
APP_NAME=Better-Student
APP_VERSION=0.1.0

# 数据库配置
DATABASE_PATH=./data/better_student.db

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 音频配置
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024

# 识别配置
RECOGNITION_TIMEOUT=5
RECOGNITION_INTERVAL=0.5
